# ============================================================
# MediDo — Variables de entorno
# ============================================================
# Copia este archivo como .env y rellena los valores reales:
#   cp .env.example .env
#
# El archivo .env NUNCA se sube a git (está en .gitignore).
#
# Nota: MediDo no tiene docker-compose.yml propio. En producción
# se gestiona desde hogarOS/docker-compose.yml con hogarOS/.env.
# Este archivo sirve como referencia de qué variables necesita.
# ============================================================

# ── Proxmox (hipervisor de virtualización) ───────────────────
# IP o hostname del servidor Proxmox
PVE_HOST=192.168.XX.XXX

# Nombre del nodo Proxmox
PVE_NODE=nombre-del-nodo

# ID del token de API (Interfaz de Programación) de Proxmox (formato: usuario@realm!nombre)
PVE_TOKEN_ID=root@pam!medido

# Secreto del token de API de Proxmox
PVE_TOKEN_SECRET=

# Verificar certificado SSL (Capa de Conexión Segura) del servidor Proxmox
PVE_VERIFY_SSL=false

# ── Home Assistant (domótica) ────────────────────────────────
# Token de larga duración de Home Assistant
HA_TOKEN=

# ── NTFY (alertas del sistema al móvil) ─────────────────────
# Topic privado compartido con ReDo para alertas del ecosistema hogarOS
NTFY_TOPIC=
